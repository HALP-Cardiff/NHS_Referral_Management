# Comma-separated list of browser origins allowed to call this API (CORS).
# Required when the frontend uses NEXT_PUBLIC_API_URL (browser talks to API directly).
# Example:
# CORS_ORIGIN=https://referral-nhs-management.netlify.app

# Local Next.js dev (if you set NEXT_PUBLIC_API_URL to the API in .env.local):
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
